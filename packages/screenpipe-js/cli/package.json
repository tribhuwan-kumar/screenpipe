{
  "name": "@screenpipe/dev",
  "version": "1.2.8",
  "description": "screenpipe development CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "screenpipe-dev": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18 --clean && chmod +x ./dist/index.js && bun link",
    "start": "bun run dist/index.js",
    "dev": "bun run src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/lib-storage": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@clack/prompts": "^0.10.1",
    "@screenpipe/browser": "^0.1.40",
    "@screenpipe/js": "^1.0.21",
    "@types/inquirer": "^9.0.9",
    "@types/tar-stream": "^3.1.4",
    "archiver": "^7.0.1",
    "async-listen": "^3.1.0",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "deepmerge": "^4.3.1",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "ignore": "^7.0.5",
    "inquirer": "^12.11.1",
    "lodash": "^4.17.23",
    "nanoid": "^5.1.6",
    "ora": "^8.2.0",
    "prompts": "^2.4.2",
    "simple-git": "^3.32.3",
    "tar-stream": "^3.1.8",
    "unzip-stream": "^0.3.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.37",
    "@types/prompts": "^2.4.9",
    "@types/unzip-stream": "^0.3.4",
    "bun-types": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
